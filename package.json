{
  "name": "auth",
  "version": "2.1.1",
  "private": true,
  "description": "Dark Avian LABS Auth Service",
  "type": "module",
  "scripts": {
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "build": "pnpm run typecheck && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "validate": "node run-quality-checks.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.61.0",
    "@fontsource-variable/inter": "^5.2.8",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.9.0",
    "better-sqlite3-session-store": "^0.1.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3"
    ]
  }
}
